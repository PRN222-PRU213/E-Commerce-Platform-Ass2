@page
@model E_Commerce_Platform_Ass2.Wed.Pages.Ticket.IndexModel

@{
    ViewData["Title"] = "Hỗ trợ - Ticket";
    var role = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "Customer";
    Layout = role == "Admin" ? "_AdminLayout" : role == "Seller" ? "_ShopDashboardLayout" : "_EShopperLayout";
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h2 class="mb-0">
                <i class="fas fa-ticket-alt me-2 text-primary"></i>Hỗ trợ của tôi
            </h2>
        </div>
        <div class="col-md-6 text-end">
            <a asp-page="Create" class="btn btn-primary">
                <i class="fas fa-plus me-1"></i>Tạo Ticket mới
            </a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-3">
                    <select class="form-select" onchange="window.location.href='?StatusFilter=' + this.value">
                        <option value="All">Tất cả trạng thái</option>
                        <option value="Open">Mở</option>
                        <option value="InProgress">Đang xử lý</option>
                        <option value="Pending">Chờ phản hồi</option>
                        <option value="Resolved">Đã giải quyết</option>
                        <option value="Closed">Đã đóng</option>
                    </select>
                </div>
            </div>

            @if (Model.Tickets.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Mã Ticket</th>
                                <th>Tiêu đề</th>
                                <th>Danh mục</th>
                                <th>Ưu tiên</th>
                                <th>Trạng thái</th>
                                <th>Phản hồi</th>
                                <th>Ngày tạo</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ticket in Model.Tickets)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">@ticket.TicketCode</span></td>
                                    <td>@ticket.Subject</td>
                                    <td>@ticket.Category</td>
                                    <td>
                                        @if (ticket.Priority == "Urgent")
                                        {
                                            <span class="badge bg-danger">Khẩn cấp</span>
                                        }
                                        else if (ticket.Priority == "High")
                                        {
                                            <span class="badge bg-warning">Cao</span>
                                        }
                                        else if (ticket.Priority == "Medium")
                                        {
                                            <span class="badge bg-info">Trung bình</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Thấp</span>
                                        }
                                    </td>
                                    <td>
                                        @if (ticket.Status == "Open")
                                        {
                                            <span class="badge bg-primary">Mở</span>
                                        }
                                        else if (ticket.Status == "InProgress")
                                        {
                                            <span class="badge bg-info">Đang xử lý</span>
                                        }
                                        else if (ticket.Status == "Pending")
                                        {
                                            <span class="badge bg-warning">Chờ phản hồi</span>
                                        }
                                        else if (ticket.Status == "Resolved")
                                        {
                                            <span class="badge bg-success">Đã giải quyết</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Đã đóng</span>
                                        }
                                    </td>
                                    <td>@ticket.ResponseCount</td>
                                    <td>@ticket.CreatedAt.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <a asp-page="Detail" asp-route-id="@ticket.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-inbox fa-4x text-muted mb-3"></i>
                    <p class="text-muted">Bạn chưa có ticket hỗ trợ nào.</p>
                    <a asp-page="Create" class="btn btn-primary">
                        <i class="fas fa-plus me-1"></i>Tạo ticket mới
                    </a>
                </div>
            }
        </div>
    </div>
</div>
