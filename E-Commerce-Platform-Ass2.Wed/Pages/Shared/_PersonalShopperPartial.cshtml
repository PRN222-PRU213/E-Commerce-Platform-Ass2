@using System.Security.Claims
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf

@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var csrfToken = Xsrf.GetAndStoreTokens(ViewContext.HttpContext).RequestToken;
    var shopperUserId = User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "guest";
}

<meta name="shopper-csrf" content="@csrfToken" />

<!-- AI Personal Shopper Widget -->
<div id="shopperWidget"
     style="display:none; position:fixed; bottom:90px; right:20px; width:420px; max-height:620px;
            background:#fff; border-radius:12px; z-index:1060; border:1px solid #dee2e6;
            box-shadow:0 8px 32px rgba(0,0,0,0.18); display:none; flex-direction:column;">

    <!-- Header -->
    <div id="shopperHeader"
         style="background:linear-gradient(135deg,#6f42c1,#e83e8c); border-radius:12px 12px 0 0;
                padding:12px 16px; display:flex; justify-content:space-between; align-items:center; cursor:pointer;">
        <div style="display:flex; align-items:center; gap:10px;">
            <span style="font-size:1.3rem;">🛍️</span>
            <div>
                <h6 style="margin:0; color:#fff; font-weight:600; font-size:0.95rem;">AI Personal Shopper</h6>
                <small style="color:rgba(255,255,255,0.85); font-size:0.75rem;">Tư vấn bộ sản phẩm hoàn chỉnh</small>
            </div>
        </div>
        <div style="display:flex; align-items:center; gap:8px;">
            <button id="clearShopperBtn" title="Xóa lịch sử chat"
                    style="background:rgba(255,255,255,0.2); border:none; border-radius:6px; color:#fff;
                           font-size:0.75rem; padding:3px 8px; cursor:pointer; line-height:1.4;">
                🗑️ Xóa
            </button>
            <span id="closeShopperBtn" style="color:#fff; font-size:1.4rem; line-height:1; cursor:pointer;">&times;</span>
        </div>
    </div>
    <!-- Messages -->
    <div id="shopperMessages"
         style="flex:1; overflow-y:auto; padding:16px; background:#f8f9fa; min-height:200px; max-height:380px;">
        <!-- Populated by personal-shopper.js (localStorage history or welcome message) -->
    </div>

    <!-- Combos Container -->
    <div id="shopperCombos" style="display:none; overflow-y:auto; max-height:0; padding:0 12px; background:#fff; transition:max-height 0.3s;"></div>

    <!-- Input -->
    <div style="padding:10px 12px; border-top:1px solid #dee2e6; background:#fff; border-radius:0 0 12px 12px; display:flex; gap:8px;">
        <input id="shopperInput" type="text" placeholder="Nhập yêu cầu mua sắm..."
               style="flex:1; border:1px solid #ced4da; border-radius:20px; padding:8px 16px; font-size:0.875rem; outline:none;" />
        <button id="shopperSendBtn"
                style="background:linear-gradient(135deg,#6f42c1,#e83e8c); border:none; border-radius:50%; width:38px; height:38px;
                       color:#fff; font-size:1rem; cursor:pointer; display:flex; align-items:center; justify-content:center;">
            ➤
        </button>
    </div>
</div>

<!-- Floating Toggle Button -->
<button id="openShopperBtn"
        title="AI Personal Shopper"
        style="position:fixed; bottom:90px; right:20px; width:56px; height:56px; border-radius:50%;
               background:linear-gradient(135deg,#6f42c1,#e83e8c); border:none; color:#fff;
               font-size:1.5rem; z-index:1050; box-shadow:0 4px 16px rgba(111,66,193,0.5);
               cursor:pointer; display:flex; align-items:center; justify-content:center;"
        aria-label="Mở AI Personal Shopper">
    🛍️
</button>

<style>
    .shopper-msg { margin-bottom: 12px; display: flex; }
    .shopper-msg--user { justify-content: flex-end; }
    .shopper-msg--ai { justify-content: flex-start; }
    .shopper-bubble {
        max-width: 82%; padding: 10px 14px; border-radius: 16px;
        font-size: 0.875rem; line-height: 1.5; word-wrap: break-word;
    }
    .shopper-msg--user .shopper-bubble { background: linear-gradient(135deg,#6f42c1,#e83e8c); color: #fff; border-bottom-right-radius: 4px; }
    .shopper-msg--ai .shopper-bubble { background: #fff; border: 1px solid #e0e0e0; color: #333; border-bottom-left-radius: 4px; }
    .shopper-typing { font-style: italic; color: #999; font-size: 0.8rem; }
    .combo-card { border: 1px solid #e0e0e0; border-radius: 10px; margin-bottom: 12px; overflow: hidden; }
    .combo-card-header { padding: 10px 14px; background: linear-gradient(135deg,#6f42c1,#e83e8c); color: #fff; }
    .combo-card-body { padding: 10px 14px; }
    .combo-product-item { display: flex; align-items: center; gap: 10px; padding: 6px 0; border-bottom: 1px solid #f0f0f0; }
    .combo-product-item:last-child { border-bottom: none; }
    .combo-product-img { width: 44px; height: 44px; object-fit: cover; border-radius: 6px; background: #f0f0f0; }
    .combo-total { font-weight: 600; color: #6f42c1; font-size: 0.9rem; padding: 8px 14px; background: #f8f0ff; }
    .btn-add-combo {
        width: 100%; padding: 8px; border: none; border-radius: 0 0 10px 10px;
        background: linear-gradient(135deg,#6f42c1,#e83e8c); color: #fff;
        font-weight: 600; cursor: pointer; font-size: 0.875rem;
    }
    .btn-add-combo:disabled { opacity: 0.6; cursor: not-allowed; }
    .style-badge {
        display: inline-block; padding: 2px 8px; border-radius: 10px;
        font-size: 0.7rem; font-weight: 600; background: rgba(255,255,255,0.25); color: #fff; margin-left: 6px;
    }
</style>

<script>
    window.__shopperIsAuthenticated = @(isAuthenticated ? "true" : "false");
    window.__shopperUserId = "@shopperUserId";
</script>
<script src="~/js/personal-shopper.js" asp-append-version="true"></script>
