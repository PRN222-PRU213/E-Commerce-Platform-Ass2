@page
@model E_Commerce_Platform_Ass2.Wed.Pages.Admin.Tickets.IndexModel

@{
    ViewData["Title"] = "Quản lý Ticket hỗ trợ";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="fas fa-ticket-alt me-2 text-primary"></i>Quản lý Ticket hỗ trợ
        </h2>
        <a asp-page="/Admin/Tickets/Templates" class="btn btn-outline-primary">
            <i class="fas fa-cogs me-1"></i> Quản lý Templates & Rules
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-2">
            <div class="card bg-primary text-white">
                <div class="card-body text-center">
                    <h3 class="mb-0">@Model.Statistics.TotalTickets</h3>
                    <small>Tổng số</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-danger text-white">
                <div class="card-body text-center">
                    <h3 class="mb-0">@Model.Statistics.OpenTickets</h3>
                    <small>Chưa xử lý</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <h3 class="mb-0">@Model.Statistics.InProgressTickets</h3>
                    <small>Đang xử lý</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <h3 class="mb-0">@Model.Statistics.ResolvedTickets</h3>
                    <small>Đã giải quyết</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-warning text-dark">
                <div class="card-body text-center">
                    <h3 class="mb-0">@Model.Statistics.TodayTickets</h3>
                    <small>Hôm nay</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-secondary text-white">
                <div class="card-body text-center">
                    <h3 class="mb-0">@(Model.Statistics.AverageResolutionTimeHours > 0 ? Model.Statistics.AverageResolutionTimeHours.ToString("N1") + "h" : "N/A")</h3>
                    <small>TB xử lý</small>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form method="get">
                <div class="row mb-3">
                    <div class="col-md-3">
                        <label class="form-label">Trạng thái</label>
                        <select name="Status" class="form-select">
                            <option value="">Tất cả</option>
                            <option value="Open" selected="@(Model.Status == "Open")">Mở</option>
                            <option value="InProgress" selected="@(Model.Status == "InProgress")">Đang xử lý</option>
                            <option value="Pending" selected="@(Model.Status == "Pending")">Chờ phản hồi</option>
                            <option value="Resolved" selected="@(Model.Status == "Resolved")">Đã giải quyết</option>
                            <option value="Closed" selected="@(Model.Status == "Closed")">Đã đóng</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Mức ưu tiên</label>
                        <select name="Priority" class="form-select">
                            <option value="">Tất cả</option>
                            <option value="Urgent" selected="@(Model.Priority == "Urgent")">Khẩn cấp</option>
                            <option value="High" selected="@(Model.Priority == "High")">Cao</option>
                            <option value="Medium" selected="@(Model.Priority == "Medium")">Trung bình</option>
                            <option value="Low" selected="@(Model.Priority == "Low")">Thấp</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Danh mục</label>
                        <select name="Category" class="form-select">
                            <option value="">Tất cả</option>
                            <option value="Kỹ thuật" selected="@(Model.Category == "Kỹ thuật")">Kỹ thuật</option>
                            <option value="Thanh toán" selected="@(Model.Category == "Thanh toán")">Thanh toán</option>
                            <option value="Khiếu nại" selected="@(Model.Category == "Khiếu nại")">Khiếu nại</option>
                            <option value="Góp ý" selected="@(Model.Category == "Góp ý")">Góp ý</option>
                            <option value="Khác" selected="@(Model.Category == "Khác")">Khác</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary me-2">
                            <i class="fas fa-filter me-1"></i> Lọc
                        </button>
                        <a asp-page="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-times"></i>
                        </a>
                    </div>
                </div>
            </form>

            @if (Model.Tickets.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Mã</th>
                                <th>Tiêu đề</th>
                                <th>Khách hàng</th>
                                <th>Danh mục</th>
                                <th>Ưu tiên</th>
                                <th>Trạng thái</th>
                                <th>Phản hồi</th>
                                <th>Ngày tạo</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ticket in Model.Tickets)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">@ticket.TicketCode</span></td>
                                    <td>
                                        <a asp-page="/Ticket/Detail" asp-route-id="@ticket.Id" class="text-decoration-none">
                                            @ticket.Subject
                                        </a>
                                    </td>
                                    <td>@ticket.CustomerName</td>
                                    <td>@ticket.Category</td>
                                    <td>
                                        @if (ticket.Priority == "Urgent")
                                        {
                                            <span class="badge bg-danger">Khẩn cấp</span>
                                        }
                                        else if (ticket.Priority == "High")
                                        {
                                            <span class="badge bg-warning">Cao</span>
                                        }
                                        else if (ticket.Priority == "Medium")
                                        {
                                            <span class="badge bg-info">Trung bình</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Thấp</span>
                                        }
                                    </td>
                                    <td>
                                        <form method="post" asp-page-handler="UpdateStatus" class="d-inline">
                                            <input type="hidden" name="ticketId" value="@ticket.Id" />
                                            <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                                                <option value="Open" selected="@(ticket.Status == "Open")">Mở</option>
                                                <option value="InProgress" selected="@(ticket.Status == "InProgress")">Đang xử lý</option>
                                                <option value="Pending" selected="@(ticket.Status == "Pending")">Chờ phản hồi</option>
                                                <option value="Resolved" selected="@(ticket.Status == "Resolved")">Đã giải quyết</option>
                                                <option value="Closed" selected="@(ticket.Status == "Closed")">Đã đóng</option>
                                            </select>
                                        </form>
                                    </td>
                                    <td>@ticket.ResponseCount</td>
                                    <td>@ticket.CreatedAt.ToString("dd/MM/yy HH:mm")</td>
                                    <td>
                                        <div class="btn-group">
                                            <a asp-page="/Ticket/Detail" asp-route-id="@ticket.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-inbox fa-4x text-muted mb-3"></i>
                    <p class="text-muted">Không có ticket nào.</p>
                </div>
            }
        </div>
    </div>
</div>
