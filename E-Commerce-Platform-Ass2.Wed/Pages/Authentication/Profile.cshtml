@page
@model E_Commerce_Platform_Ass2.Wed.Pages.Authentication.ProfileModel
@{
    ViewData["Title"] = "Hồ sơ người dùng";
    Layout = "~/Pages/Shared/_EShopperLayout.cshtml";
}

@if (Model.UserInfo == null)
{
    <div class="container-fluid py-5">
        <div class="alert alert-danger">Không tìm thấy thông tin người dùng.</div>
    </div>
    return;
}

<!-- Profile Start -->
<div class="container-fluid py-5">
    <div class="row px-xl-5">
        <div class="col-lg-12">
            <div class="bg-light p-4 rounded shadow-sm">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                        <i class="fas fa-user text-white" style="font-size: 2rem;"></i>
                    </div>
                    <div class="ml-4">
                        <h3 class="font-weight-semi-bold mb-1">@Model.UserInfo.Name</h3>
                        <p class="text-muted mb-0">
                            <i class="fas fa-envelope text-primary mr-2"></i>@Model.UserInfo.Email
                        </p>
                    </div>
                </div>

                <hr class="my-4">

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <h5 class="card-title font-weight-semi-bold mb-3">
                                    <i class="fas fa-info-circle text-primary mr-2"></i>Thông tin cá nhân
                                </h5>
                                <div class="mb-3">
                                    <label class="text-muted small">Họ và tên</label>
                                    <p class="mb-0 font-weight-semi-bold">@Model.UserInfo.Name</p>
                                </div>
                                <div class="mb-3">
                                    <label class="text-muted small">Email</label>
                                    <p class="mb-0 font-weight-semi-bold">@Model.UserInfo.Email</p>
                                </div>
                                <div>
                                    <label class="text-muted small">Vai trò</label>
                                    <p class="mb-0">
                                        <span class="badge badge-primary">@Model.UserInfo.Role</span>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 mb-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <h5 class="card-title font-weight-semi-bold mb-3">
                                    <i class="fas fa-cog text-primary mr-2"></i>Tùy chọn
                                </h5>
                                <div class="d-flex flex-column">
                                    <a href="#" class="btn btn-outline-primary mb-2 text-left">
                                        <i class="fas fa-edit mr-2"></i>Chỉnh sửa hồ sơ
                                    </a>
                                    <a href="#" class="btn btn-outline-primary mb-2 text-left">
                                        <i class="fas fa-key mr-2"></i>Đổi mật khẩu
                                    </a>
                                    <a href="#" class="btn btn-outline-primary mb-2 text-left">
                                        <i class="fas fa-shopping-bag mr-2"></i>Đơn hàng của tôi
                                    </a>
                                    <form asp-page="/Authentication/Logout" method="post" class="mt-2">
                                        <button type="submit" class="btn btn-outline-danger btn-block text-left">
                                            <i class="fas fa-sign-out-alt mr-2"></i>Đăng xuất
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                    @if (string.Equals(Model.UserInfo.Role, "Admin", StringComparison.OrdinalIgnoreCase) && Model.AdminWallet != null)
                    {
                        <div class="col-12 mb-4">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body">
                                    <h5 class="card-title font-weight-semi-bold mb-3">
                                        <i class="fas fa-wallet text-success mr-2"></i>Ví Admin (nhận chiết khấu từ shop)
                                    </h5>

                                    <div class="row">
                                        <div class="col-md-4 mb-3">
                                            <label class="text-muted small">Số dư hiện tại</label>
                                            <p class="mb-0 h4 text-success font-weight-bold">@Model.AdminWallet.Balance.ToString("N0") đ</p>
                                        </div>
                                        <div class="col-md-4 mb-3">
                                            <label class="text-muted small">Biến động gần nhất</label>
                                            <p class="mb-0 font-weight-semi-bold">
                                                @((Model.AdminWallet.LastChangeAmount ?? 0).ToString("N0")) đ
                                                <span class="badge badge-info ml-2">@Model.AdminWallet.LastChangeType</span>
                                            </p>
                                        </div>
                                        <div class="col-md-4 mb-3">
                                            <label class="text-muted small">Cập nhật lúc</label>
                                            <p class="mb-0 font-weight-semi-bold">@Model.AdminWallet.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                                        </div>
                                    </div>

                                    <hr class="my-3" />

                                    <h6 class="font-weight-semi-bold mb-3">Giao dịch chiết khấu gần đây</h6>

                                    @if (Model.AdminCommissionTransactions.Any())
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-sm table-striped mb-0">
                                                <thead>
                                                    <tr>
                                                        <th>Thời gian</th>
                                                        <th>Loại</th>
                                                        <th>Mô tả</th>
                                                        <th class="text-right">Số tiền</th>
                                                        <th class="text-right">Số dư sau GD</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var tx in Model.AdminCommissionTransactions.Take(10))
                                                    {
                                                        <tr>
                                                            <td>@tx.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                                            <td><span class="badge badge-success">@tx.TransactionType</span></td>
                                                            <td>@tx.Description</td>
                                                            <td class="text-right text-success font-weight-semi-bold">+@tx.Amount.ToString("N0") đ</td>
                                                            <td class="text-right">@tx.BalanceAfter.ToString("N0") đ</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="alert alert-light mb-0">
                                            Chưa có giao dịch chiết khấu nào từ shop.
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Profile End -->
